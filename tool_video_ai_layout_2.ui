  <property name="styleSheet">
   <string notr="true">QMainWindow, QWidget#centralwidget {
    background-color: #070b14;
    color: #e8edf7;
    font-family: Arial;
}
QLabel {
    color: #e8edf7;
}
QLineEdit, QTextEdit, QPlainTextEdit, QComboBox, QSpinBox {
    background-color: #101827;
    color: #f3f6ff;
    border: 1px solid #2b3a55;
    border-radius: 8px;
    padding: 8px;
    selection-background-color: #7c3aed;
}
QLineEdit:focus, QTextEdit:focus, QComboBox:focus, QSpinBox:focus {
    border: 1px solid #8b5cf6;
}
QPushButton {
    background-color: #7c3aed;
    color: white;
    border: none;
    border-radius: 8px;
    padding: 8px 12px;
    font-weight: bold;
}
QPushButton:hover {
    background-color: #8b5cf6;
}
QPushButton:pressed {
    background-color: #6d28d9;
}
QTabWidget::pane {
    border: 1px solid #25344d;
    border-radius: 10px;
    top: -1px;
    background: #080d18;
}
QTabBar::tab {
    background: #111a2b;
    color: #f4f7ff;
    border: 1px solid #334155;
    padding: 10px 18px;
    margin-right: 8px;
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    font-weight: bold;
}
QTabBar::tab:selected {
    background: #8b5cf6;
    color: white;
}
QScrollArea {
    border: none;
    background: transparent;
}
QFrame#sidebarFrame, QFrame#mainFrame {
    background-color: #070b14;
}
QFrame#boxFrame, QFrame#characterFrame, QFrame#sceneCard_1, QFrame#sceneCard_2, QFrame#sceneCard_3, QFrame#sceneCard_4, QFrame#sceneCard_5, QFrame#sceneCard_6 {
    background-color: #0b1220;
    border: 1px solid #26364f;
    border-radius: 12px;
}
QFrame#sceneCard_1, QFrame#sceneCard_2, QFrame#sceneCard_3, QFrame#sceneCard_4, QFrame#sceneCard_5, QFrame#sceneCard_6 {
    border-style: dashed;
    border-color: #f59e0b;
}
QLabel#sectionTitle, QLabel#sectionTitle_2, QLabel#sectionTitle_3 {
    color: #ffffff;
    font-size: 18px;
    font-weight: bold;
}
QLabel#hintLabel, QLabel#hintLabel_2, QLabel#hintLabel_3, QLabel#hintLabel_4, QLabel#hintLabel_5, QLabel#hintLabel_6 {
    color: #8b95a7;
}
QLabel#blueLabel, QLabel#blueLabel_2, QLabel#blueLabel_3, QLabel#blueLabel_4, QLabel#blueLabel_5, QLabel#blueLabel_6 {
    color: #22d3ee;
    font-weight: bold;
}
QLabel#orangeLabel {
    color: #f59e0b;
    font-weight: bold;
}
QCheckBox {
    color: #f3f6ff;
    spacing: 8px;
}
QCheckBox::indicator {
    width: 42px;
    height: 22px;
}
QCheckBox::indicator:unchecked {
    border-radius: 11px;
    background-color: #374151;
    border: 1px solid #4b5563;
}
QCheckBox::indicator:checked {
    border-radius: 11px;
    background-color: #818cf8;
    border: 1px solid #a5b4fc;
}</string>
